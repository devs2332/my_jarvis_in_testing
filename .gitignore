*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ===== Virtual Environments =====
venv/
ENV/
env/
.venv/

# ===== IDE =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== Node / Frontend =====
node_modules/
frontend/node_modules/
frontend/dist/
